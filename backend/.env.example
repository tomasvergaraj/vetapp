# ==================== Aplicación ====================
APP_NAME="Veterinaria a domicilio"
APP_ENV=development
DEBUG=true

# ==================== Servidor ====================
HOST=0.0.0.0
PORT=8000

# ==================== Base de datos ====================
# Formato: postgresql+psycopg2://USUARIO:PASSWORD@HOST:PUERTO/NOMBRE_DB
DATABASE_URL=postgresql+psycopg2://vetuser:vetpass@localhost:5432/vetapp

# ==================== Seguridad / JWT ====================
# IMPORTANTE: generar una nueva en producción con:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-please-use-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ==================== CORS ====================
# Lista separada por comas. En producción, usar dominios reales.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ==================== Admin inicial (seed) ====================
ADMIN_EMAIL=admin@veterinaria.cl
ADMIN_PASSWORD=Cambiar123!
ADMIN_FULL_NAME=Veterinaria Administradora
